# ── Servidor ──────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*
ETL_ENABLED=true
ETL_RUN_ON_START=false
LOG_LEVEL=info

# ── PostgreSQL ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=simgp_tachira
DB_USER=simgp_user
DB_PASSWORD=simgp_pass_dev
DB_SSL=false

# ── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_en_produccion
JWT_EXPIRES_IN=8h

# ── IA ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Redes sociales ────────────────────────────
# Instagram Graph API — Meta for Developers
INSTAGRAM_ACCESS_TOKEN=

# Facebook Graph API — Meta for Developers
FACEBOOK_ACCESS_TOKEN=

# X/Twitter API v2 — developer.twitter.com
TWITTER_BEARER_TOKEN=

# TikTok for Developers
TIKTOK_ACCESS_TOKEN=

# Telegram Bot — @BotFather
TELEGRAM_BOT_TOKEN=
