{
  "name": "simgp-tachira-backend",
  "version": "1.0.0",
  "description": "Sistema Inteligente de Monitoreo de Gestión Pública del Estado Táchira",
  "main": "src/server.js",
  "scripts": {
    "start":   "node src/server.js",
    "dev":     "nodemon src/server.js",
    "migrate": "node ../database/migrate.js",
    "seed":    "node ../database/seeds/run-seeds.js",
    "test":    "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "etl:run": "node -e \"require('dotenv').config(); const {ejecutarPipeline}=require('./src/etl/pipeline'); ejecutarPipeline().then(r=>console.log(JSON.stringify(r,null,2)))\""
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js"],
    "coverageThreshold": {
      "global": { "branches": 60, "functions": 60, "lines": 60 }
    }
  },
  "dependencies": {
    "express":            "^4.18.2",
    "pg":                 "^8.11.3",
    "redis":              "^4.6.10",
    "bull":               "^4.11.5",
    "jsonwebtoken":       "^9.0.2",
    "bcryptjs":           "^2.4.3",
    "cors":               "^2.8.5",
    "helmet":             "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "joi":                "^17.11.0",
    "dotenv":             "^16.3.1",
    "axios":              "^1.6.2",
    "ws":                 "^8.14.2",
    "node-cron":          "^3.0.3",
    "openai":             "^4.20.1",
    "@anthropic-ai/sdk":  "^0.9.1",
    "cheerio":            "^1.0.0-rc.12",
    "rss-parser":         "^3.13.0",
    "winston":            "^3.11.0",
    "uuid":               "^9.0.0",
    "compression":        "^1.7.4",
    "pdfkit":             "^0.14.0",
    "exceljs":            "^4.4.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest":    "^29.7.0"
  }
}
